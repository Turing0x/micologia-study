---
import Layout from '../layouts/Layout.astro';
import TopicCard from '../components/TopicCard.astro';
import InfoBox from '../components/InfoBox.astro';
---

<Layout title="Inicio">
  <div class="hero animate-in">
    <div class="hero__badge">🍄 Guía de Estudio Interactiva</div>
    <h1 class="hero__title">Micología Clínica</h1>
    <p class="hero__subtitle">
      Repasa los temas de Micología Clínica de forma estructurada y visual.
      Fichas, tablas, quizzes y glosario en un solo lugar.
    </p>
    <div class="hero__ctas">
      <a href="/quiz" class="btn btn-primary">🎯 Empezar Quiz</a>
      <a href="/glosario" class="btn btn-outline">📖 Ver Glosario</a>
    </div>
  </div>

  <section>
    <h2 class="topics-heading">📚 Temas del Temario</h2>
    <div class="topics-grid">
      <div class="animate-in delay-1">
        <TopicCard
          href="/generalidades"
          icon="🔬"
          title="Generalidades de Micología"
          description="Morfología fúngica, pasos del diagnóstico microbiológico y clasificación clínica de las micosis."
          color="primary"
          tags={['Morfología', 'Diagnóstico', 'Clasificación']}
        />
      </div>
      <div class="animate-in delay-2">
        <TopicCard
          href="/candidiasis"
          icon="🦠"
          title="Candidiasis"
          description="Género Candida, formas clínicas (orofaríngea, vaginitis, candidemia), resistencias y diagnóstico."
          color="secondary"
          tags={['Candida', 'Candidemia', 'Resistencias', 'Tubo germinativo']}
        />
      </div>
      <div class="animate-in delay-3">
        <TopicCard
          href="/dermatofitosis"
          icon="🦶"
          title="Dermatofitosis & Aspergilosis"
          description="Tiñas, géneros de dermatofitos, identificación de especies y aspergilosis invasiva."
          color="accent"
          tags={['Tineas', 'Trichophyton', 'Microsporum', 'Aspergillus']}
        />
      </div>
      <div class="animate-in delay-4">
        <TopicCard
          href="/api20c"
          icon="🧫"
          title="API 20 C AUX"
          description="Sistema de identificación de levaduras de bioMérieux: procedimiento, pruebas y lectura."
          color="danger"
          tags={['bioMérieux', 'Asimilación', 'Levaduras', 'McFarland']}
        />
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="quick-access animate-in delay-5">
    <h2>⚡ Acceso Rápido</h2>
    <div class="quick-grid">
      <a href="/quiz" class="quick-card quick-card--quiz">
        <span class="quick-card__icon">❓</span>
        <span class="quick-card__title">Quiz Interactivo</span>
        <span class="quick-card__desc">32 preguntas tipo test de todos los temas con feedback inmediato</span>
      </a>
      <a href="/glosario" class="quick-card quick-card--glosario">
        <span class="quick-card__icon">📖</span>
        <span class="quick-card__title">Glosario Buscable</span>
        <span class="quick-card__desc">Todos los términos técnicos con definiciones, organizados por categorías</span>
      </a>
    </div>
  </section>

  <hr class="section-divider" />

  <section class="animate-in delay-6">
    <h2>📌 Resumen Express — Lo Más Preguntado</h2>
    <InfoBox type="exam" title="Claves de examen">
      <ul>
        <li><strong>Resistencias de Candida:</strong> C. krusei (intrínseca a fluconazol), C. glabrata y C. guilliermondii (reducida). C. lusitaniae (Anfotericina B).</li>
        <li><strong>T. rubrum vs T. mentagrophytes:</strong> ureasa (–/+), reverso colonia (rojo/marrón).</li>
        <li><strong>Aspergillus — Fiálides:</strong> A. fumigatus 180° (uniseriado); A. flavus/niger/terreus 360°.</li>
        <li><strong>Candidemia:</strong> mortalidad ~40%, sensibilidad hemocultivo ~50%, 5–10% sepsis nosocomiales.</li>
        <li><strong>Galactomanano:</strong> específico de Aspergillus. β-D-Glucano: inespecífico (Candida, Aspergillus, Pneumocystis).</li>
        <li><strong>Dimorfismo:</strong> levadura a 37°C, moho a 25°C (Histoplasma, Sporothrix).</li>
        <li><strong>API 20C:</strong> 19 pruebas asimilación + 1 control. McFarland nº 2. Lectura por turbidez.</li>
        <li><strong>Epidermophyton:</strong> único género sin microconidias.</li>
      </ul>
    </InfoBox>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 1rem 2.5rem;
    max-width: 680px;
    margin: 0 auto 2.5rem;
  }
  .hero__badge {
    display: inline-block;
    background: var(--primary);
    color: #fff;
    border-radius: 99px;
    padding: 0.25rem 1rem;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    margin-bottom: 1rem;
  }
  .hero__title {
    font-size: clamp(2rem, 6vw, 3.5rem);
    margin: 0 0 0.75rem;
    background: linear-gradient(135deg, var(--primary-dark), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero__subtitle {
    color: var(--text-muted);
    font-size: 1.05rem;
    margin: 0 0 1.75rem;
    line-height: 1.6;
  }
  .hero__ctas { display: flex; gap: 0.75rem; justify-content: center; flex-wrap: wrap; }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .btn:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
  .btn-primary { background: var(--primary); color: #fff; }
  .btn-outline { border: 2px solid var(--primary); color: var(--primary); background: transparent; }

  .topics-heading { margin: 0 0 1.25rem; }
  .topics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }

  .quick-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }
  .quick-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    border-radius: var(--radius);
    text-decoration: none;
    color: #fff;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: var(--shadow);
  }
  .quick-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-lg); }
  .quick-card--quiz    { background: linear-gradient(135deg, #2d5238, #4a7c59); }
  .quick-card--glosario { background: linear-gradient(135deg, #5a1a8a, #8b2fc9); }
  .quick-card__icon { font-size: 2.2rem; }
  .quick-card__title { font-size: 1.15rem; font-weight: 700; }
  .quick-card__desc { font-size: 0.88rem; opacity: 0.88; line-height: 1.5; }
</style>
